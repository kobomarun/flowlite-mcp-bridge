{
  "name": "flowlite-mcp-bridge",
  "version": "0.2.1",
  "description": "A Model Context Protocol (MCP) bridge that exposes FlowLite workflow automation as structured AI tools — with compliance logging and audit trails.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "flowlite",
    "workflow",
    "ai-tools",
    "automation",
    "audit-trail",
    "compliance"
  ],
  "author": "FlowLite MCP Bridge Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kobomarun/flowlite-mcp-bridge.git"
  },
  "homepage": "https://github.com/kobomarun/flowlite-mcp-bridge#readme",
  "bugs": {
    "url": "https://github.com/kobomarun/flowlite-mcp-bridge/issues"
  },
  "type": "module",
  "main": "dist/cli/serve.js",
  "bin": {
    "flowlite-mcp": "dist/cli/serve.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/cli/serve.js",
    "dev": "tsx watch src/cli/serve.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "setup-demo": "node scripts/setup-demo.js",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "flowlite": "^1.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.23.3",
    "yaml": "^2.4.2",
    "winston": "^3.13.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.16.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}