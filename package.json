{
  "name": "flowlite-mcp-bridge",
  "version": "0.1.0",
  "description": "A Model Context Protocol (MCP) bridge that exposes FlowLite workflow automation as structured AI tools — with compliance logging and audit trails.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "flowlite",
    "workflow",
    "ai-tools",
    "automation",
    "audit-trail",
    "compliance"
  ],
  "author": "FlowLite MCP Bridge Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/flowlite-mcp-bridge.git"
  },
  "homepage": "https://github.com/your-org/flowlite-mcp-bridge#readme",
  "bugs": {
    "url": "https://github.com/your-org/flowlite-mcp-bridge/issues"
  },
  "type": "module",
  "main": "dist/cli/serve.js",
  "bin": {
    "flowlite-mcp": "dist/cli/serve.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/cli/serve.js",
    "dev": "tsx watch src/cli/serve.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "setup-demo": "node scripts/setup-demo.js",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "flowlite": "^1.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3",
    "yaml": "^2.4.2",
    "winston": "^3.13.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}